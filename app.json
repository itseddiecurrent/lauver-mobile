{
  "expo": {
    "name": "lauver-mobile-app",
    "slug": "lauver-mobile-app",
    "scheme": "lauver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.lauver.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Lauver reads your workouts to track your training and find matching athletes.",
        "NSHealthUpdateUsageDescription": "Lauver saves workouts to Apple Health.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "ai.lauver.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5b026c8a-9bd3-4dd3-b42d-b6c5ad85b472"
      }
    }
  }
}
